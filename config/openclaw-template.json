{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": ["anthropic/claude-sonnet-4-5", "openai/gpt-5.2"]
      },
      "heartbeat": {
        "every": "30m",
        "model": "anthropic/claude-haiku-4-5",
        "lightContext": true
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 50000
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 50000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 12000
        }
      }
    }
  },
  "cron": {
    "maxConcurrentRuns": 3
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    },
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 6,
      "criticalThreshold": 12
    }
  },
  "NOTE": "This is a template. The install script adapts it to your setup."
}
